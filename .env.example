# Forge environment variables
# Copy this file to .env and fill in your values.
#
# These are exposed to the client bundle (EXPO_PUBLIC_ prefix). The Supabase
# anon key is safe to ship publicly because Row Level Security protects data.
# Without these set, Forge runs in local demo mode (data stored on-device).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-side only (set as Supabase Edge Function secrets, NOT here) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
